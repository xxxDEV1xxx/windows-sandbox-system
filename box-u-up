function Get-ProcessInfo {
    param($PID)
    try {
        $proc = Get-Process -Id $PID -ErrorAction Stop
        return @{
            Name = $proc.ProcessName
            Path = $proc.MainModule.FileName
            PID  = $PID
        }
    } catch {
        return @{Name="Unknown"; Path=""; PID=$PID}
    }
}

function Sync-ToOriginal {
    param($SandboxFile, $SandboxRoot, $OriginalRoot)
    
    $rel = $SandboxFile.Substring($SandboxRoot.Length)
    $original = $OriginalRoot + $rel
    
    if (Test-Path $original) {
        # Temporarily grant admin write to original
        & icacls.exe "$original" `
            /grant "NT AUTHORITY\SYSTEM:(M)" `
            /C /Q 2>&1 | Out-Null
        
        Copy-Item -Path $SandboxFile `
            -Destination $original `
            -Force
        
        # Remove temporary write access
        & icacls.exe "$original" `
            /remove:g "NT AUTHORITY\SYSTEM" `
            /C /Q 2>&1 | Out-Null
        & icacls.exe "$original" `
            /grant "NT AUTHORITY\SYSTEM:(RX)" `
            /C /Q 2>&1 | Out-Null
        
        return $true
    }
    return $false
}

function Revert-SandboxFile {
    param($SandboxFile, $SandboxRoot, $OriginalRoot)
    
    $rel = $SandboxFile.Substring($SandboxRoot.Length)
    $original = $OriginalRoot + $rel
    
    if (Test-Path $original) {
        Copy-Item -Path $original `
            -Destination $SandboxFile `
            -Force
    }
}

# Set up FileSystemWatcher for each sandbox path
$watchers = @()
$changeQueue = [System.Collections.Concurrent.ConcurrentQueue[PSObject]]::new()

foreach ($sandboxPath in (Get-ChildItem $SandboxRoot `
    -Directory | Select-Object -ExpandProperty FullName)) {
    
    $watcher = New-Object System.IO.FileSystemWatcher
    $watcher.Path = $sandboxPath
    $watcher.Filter = "*.*"
    $watcher.IncludeSubdirectories = $true
    $watcher.NotifyFilter = [System.IO.NotifyFilters](
        [System.IO.NotifyFilters]::FileName -bor
        [System.IO.NotifyFilters]::LastWrite -bor
        [System.IO.NotifyFilters]::Size
    )
    
    # Queue change events
    $onChange = {
        $e = $Event
        $changeQueue.Enqueue([PSCustomObject]@{
            FullPath   = $e.SourceArgs[1].FullPath
            ChangeType = $e.SourceArgs[1].ChangeType
            Timestamp  = Get-Date
        })
    }
    
    Register-ObjectEvent $watcher Changed `
        -Action $onChange | Out-Null
    Register-ObjectEvent $watcher Created `
        -Action $onChange | Out-Null
    
    $watcher.EnableRaisingEvents = $true
    $watchers += $watcher
    
    Write-Host "[WATCHER] Monitoring: $sandboxPath"
}

Write-Host "[WATCHER] Sandbox monitor active"
Write-Host "[WATCHER] Press Ctrl-C to stop"

# Main processing loop
try {
    while ($true) {
        $change = $null
        
        if ($changeQueue.TryDequeue([ref]$change)) {
            $filePath = $change.FullPath
            $changeType = $change.ChangeType
            
            # Find which process accessed the file
            # via handle enumeration
            $accessingPID = $null
            try {
                $handles = & handle.exe `
                    "$filePath" 2>$null
                if ($handles) {
                    $pidLine = $handles | 
                        Select-String "pid:"
                    if ($pidLine) {
                        $accessingPID = ($pidLine -split `
                            "pid:")[1] -split " " | 
                            Select-Object -First 1
                    }
                }
            } catch {}
            
            $procInfo = if ($accessingPID) {
                Get-ProcessInfo -PID $accessingPID
            } else {
                @{Name="Unknown"; Path=""; PID=0}
            }
            
            # Log the attempt
            $logEntry = "[$(Get-Date -Format 'o')] " +
                "SANDBOX_ACCESS: $($procInfo.Name) " +
                "PID:$($procInfo.PID) " +
                "Action:$changeType " +
                "File:$filePath"
            Add-Content -Path $LogPath -Value $logEntry
            
            Write-Host "[CHANGE] $($procInfo.Name): " `
                "$changeType $filePath" `
                -ForegroundColor Yellow
            
            # Show approval prompt
            $decision = Show-ApprovalPrompt `
                -ProcessName $procInfo.Name `
                -PID $procInfo.PID `
                -FilePath $filePath `
                -Action $changeType
            
            if ($decision -eq "ALLOW") {
                # Sync sandbox change to original
                $synced = Sync-ToOriginal `
                    -SandboxFile $filePath `
                    -SandboxRoot $SandboxRoot `
                    -OriginalRoot "C:\Windows"
                
                $result = if ($synced) {
                    "APPROVED_SYNCED"
                } else {
                    "APPROVED_NO_ORIGINAL"
                }
                
                Write-Host "[ALLOW] Change approved" `
                    -ForegroundColor Green
            } else {
                # Revert sandbox file to original
                Revert-SandboxFile `
                    -SandboxFile $filePath `
                    -SandboxRoot $SandboxRoot `
                    -OriginalRoot "C:\Windows"
                
                $result = "DENIED_REVERTED"
                Write-Host "[DENY] Change rejected and reverted" `
                    -ForegroundColor Red
            }
            
            # Log decision
            Add-Content -Path $LogPath `
                -Value "  DECISION: $result"
        }
        
        Start-Sleep -Milliseconds 100
    }
} finally {
    $watchers | ForEach-Object {
        $_.EnableRaisingEvents = $false
        $_.Dispose()
    }
}
