# Verify sandbox exists
$sandboxExists = Test-Path $SANDBOX_ROOT
Write-Log "Sandbox exists: $sandboxExists"

# Verify watcher running
$watcherRunning = Get-Service "CTW11SandboxWatcher" `
    -ErrorAction SilentlyContinue
Write-Log "Watcher service: $($watcherRunning.Status)"

