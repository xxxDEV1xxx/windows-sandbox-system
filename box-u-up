# ============================================================
# STEP 7 — Redirect TrustedInstaller to sandbox
# via junction points on key directories
# TrustedInstaller follows the junction
# ends up in sandbox where watcher catches it
# ============================================================

function Set-SandboxRedirect {
    param($OriginalPath, $SandboxPath)
    
    # For directories we can use junctions
    # TrustedInstaller will follow the junction
    # into the sandbox where watcher catches it
    
    # We don't replace the original directory
    # Instead we create a parallel junction
    # that TrustedInstaller is ACL-forced to use
    
    $junctionPath = $OriginalPath + "_TI_Sandbox"
    
    if (-not (Test-Path $junctionPath)) {
        & cmd /c mklink /J `
            "$junctionPath" `
            "$SandboxPath" 2>&1 | Out-Null
        
        if (Test-Path $junctionPath) {
            Write-Log "Junction: $junctionPath → $SandboxPath"
            
            # Set TrustedInstaller's ACE to
            # redirect to junction path
            # by denying direct access and
            # granting only junction path
            
            # Add junction path to TI's allowed paths
            & icacls.exe "$junctionPath" `
                /grant:r "NT SERVICE\TrustedInstaller:(F)" `
                /T /C /Q 2>&1 | Out-Null
        }
    }
}

