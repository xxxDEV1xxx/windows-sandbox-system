# ============================================================
# STEP 4 — Set permissions
# Original files: admin owns, TrustedInstaller read-only
# Sandbox files: TrustedInstaller can attempt write
#                but watcher fires before commit
# ============================================================

function Set-SandboxACL {
    param($OriginalPath, $SandboxPath, $AdminSID)
    
    Write-Log "Setting ACLs: $OriginalPath"
    
    $adminAccount = New-Object `
        System.Security.Principal.SecurityIdentifier($AdminSID)
    
    # ---- ORIGINAL FILES: Admin owns, TI reads only ----
    
    # Take ownership for admin
    & takeown.exe /F "$OriginalPath" `
        /R /A /D Y 2>&1 | Out-Null
    
    & icacls.exe "$OriginalPath" `
        /setowner "$adminName" `
        /T /C /Q 2>&1 | Out-Null
    
    # Grant admin full control
    & icacls.exe "$OriginalPath" `
        /grant:r "${adminName}:(F)" `
        /T /C /Q 2>&1 | Out-Null
    
    # SYSTEM and TrustedInstaller: read + execute only
    # Critically: NO write, NO modify
    & icacls.exe "$OriginalPath" `
        /grant:r "NT AUTHORITY\SYSTEM:(RX)" `
        /T /C /Q 2>&1 | Out-Null
    
    & icacls.exe "$OriginalPath" `
        /grant:r "NT SERVICE\TrustedInstaller:(RX)" `
        /T /C /Q 2>&1 | Out-Null
    
    & icacls.exe "$OriginalPath" `
        /grant:r "BUILTIN\Administrators:(RX)" `
        /T /C /Q 2>&1 | Out-Null
    
    # Deny write to TrustedInstaller explicitly
    & icacls.exe "$OriginalPath" `
        /deny "NT SERVICE\TrustedInstaller:(W,M,D,DC)" `
        /T /C /Q 2>&1 | Out-Null
    
    Write-Log "  Original: admin=Full, TI=ReadOnly" 'Green'
    
    # ---- SANDBOX: TrustedInstaller can write here ----
    # But watcher monitors every write
    
    & icacls.exe "$SandboxPath" `
        /grant:r "${adminName}:(F)" `
        /T /C /Q 2>&1 | Out-Null
    
    & icacls.exe "$SandboxPath" `
        /grant:r "NT AUTHORITY\SYSTEM:(F)" `
        /T /C /Q 2>&1 | Out-Null
    
    & icacls.exe "$SandboxPath" `
        /grant:r "NT SERVICE\TrustedInstaller:(F)" `
        /T /C /Q 2>&1 | Out-Null
    
    Write-Log "  Sandbox: TI=Full (monitored)" 'Yellow'
}

# Apply ACLs
foreach ($path in $SANDBOX_PATHS.Keys) {
    $sandbox = $SANDBOX_PATHS[$path]
    if (Test-Path $path) {
        Set-SandboxACL `
            -OriginalPath $path `
            -SandboxPath $sandbox `
            -AdminSID $adminSID
    }
}
