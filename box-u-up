# ============================================================
# STEP 3 — Build sandbox with hard links
# Hard links share the inode — reads return real data
# Writes are intercepted before they commit
# ============================================================

function Build-Sandbox {
    param($SourcePath, $SandboxPath)
    
    Write-Log "Building sandbox: $SandboxPath"
    New-Item -ItemType Directory -Path $SandboxPath `
        -Force | Out-Null
    
    $linked = 0
    $failed = 0
    
    Get-ChildItem -Path $SourcePath `
        -Recurse -Force `
        -ErrorAction SilentlyContinue |
        Where-Object {-not $_.PSIsContainer} |
        ForEach-Object {
            $rel    = $_.FullName.Substring(
                $SourcePath.Length)
            $dest   = $SandboxPath + $rel
            $destDir = Split-Path $dest -Parent
            
            # Create directory structure
            if (-not (Test-Path $destDir)) {
                New-Item -ItemType Directory `
                    -Path $destDir -Force | Out-Null
            }
            
            # Try hard link first (same volume = works)
            try {
                if (-not (Test-Path $dest)) {
                    # Hard link: same inode, same data
                    # Read from either path = same file
                    & cmd /c mklink /H `
                        "$dest" "$($_.FullName)" `
                        2>$null | Out-Null
                    
                    if (Test-Path $dest) {
                        $linked++
                    } else {
                        # Fallback: symbolic link
                        New-Item -ItemType SymbolicLink `
                            -Path $dest `
                            -Target $_.FullName `
                            -Force | Out-Null
                        $linked++
                    }
                }
            } catch {
                $failed++
            }
        }
    
    Write-Log "  Linked: $linked, Failed: $failed"
}

# Build sandboxes for critical paths
foreach ($path in $SANDBOX_PATHS.Keys) {
    $sandbox = $SANDBOX_PATHS[$path]
    if (Test-Path $path) {
        Build-Sandbox -SourcePath $path `
            -SandboxPath $sandbox
    }
}
